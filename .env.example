# ============================================
# Frontend - Configuración Pública (Vite)
# ============================================
# AVISO: Solo variables con prefijo VITE_ se exponen al build.
# Todo lo que esté aquí será VISIBLE en el navegador (F12).
# NO incluir secretos, contraseñas ni tokens privados.
#
# En Docker, estas variables las inyecta docker-compose.yml
# desde el .env raíz. Este archivo es solo para desarrollo
# local sin Docker: cp .env.example .env
# ============================================

# URL del Backend/API (Requerida)
VITE_API_URL=http://localhost:3000

# Entorno de ejecución (opcional, default: development)
VITE_APP_ENV=development